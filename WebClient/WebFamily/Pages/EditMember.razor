@page "/edit-member/{Id:int}"
@using Family.Shared
@using WebFamily.Services
@inject IFamilyClientService FamilyService
@inject NavigationManager Nav
@inject IJSRuntime JS
@using MyGender = Family.Shared.Gender

<div class="form-container container py-4">
    <!-- Адаптивная карточка без жестких границ -->
    <div class="card border shadow-sm rounded-4 overflow-hidden">

        <!-- Шапка карты в едином стиле приложения -->
        <div class="card-header bg-primary text-white py-3 px-4 border-0">
            <h3 class="mb-0 fs-5 fw-bold">Редактировать родственника</h3>
        </div>

        <div class="card-body p-4 px-md-5">
            @if (_isLoading)
            {
                <div class="d-flex flex-column align-items-center py-5">
                    <div class="spinner-border text-primary mb-3" role="status"></div>
                    <p class="text-muted fw-medium">Загрузка данных родственника...</p>
                </div>
            }
            else if (_editMember == null)
            {
                <div class="alert alert-danger text-center rounded-3 m-0" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> Родственник с указанным ID не найден.
                </div>
            }
            else
            {
                <EditForm Model="@_editMember" OnValidSubmit="HandleFormSubmit">
                    <DataAnnotationsValidator />

                    @if (context.GetValidationMessages().Any())
                    {
                        <!-- Блок ошибок, корректно работающий в темной теме -->
                        <div class="alert alert-danger d-flex align-items-center p-3 mb-4 rounded-3 border-start border-danger border-4">
                            <ValidationSummary class="text-danger mb-0 fs-6 list-unstyled ps-0" />
                        </div>
                    }

                    <!-- Секция: Фотография профиля -->
                    <div class="mb-4 text-center">
                        <h5 class="section-title text-start fw-semibold border-bottom pb-2 mb-3 text-uppercase tracking-wider">
                            Фотография профиля
                        </h5>
                        <div class="d-flex flex-column align-items-center gap-3 my-3">
                            <div class="avatar-preview-box border rounded-circle d-flex align-items-center justify-content-center shadow-sm">
                                @if (!string.IsNullOrEmpty(_previewPhotoUrl))
                                {
                                    <img src="@_previewPhotoUrl" class="avatar-img" alt="Фото" />
                                }
                                else
                                {
                                    <span class="fs-1 text-muted">👤</span>
                                }
                            </div>
                            <div>
                                <button type="button" class="btn btn-outline-primary btn-sm rounded-3 px-3 fw-medium"
                                        @onclick="TriggerFileInput">
                                    Изменить изображение
                                </button>
                                @if (_selectedFile != null || !string.IsNullOrEmpty(_editMember.PhotoUrl))
                                {
                                    <button type="button"
                                            class="btn btn-link text-danger btn-sm p-0 ms-2 text-decoration-none fw-medium"
                                            @onclick="ClearSelectedPhoto">
                                        Удалить фото
                                    </button>
                                }
                            </div>
                            <InputFile @ref="_fileInput" id="photoFormUploadInput" OnChange="OnPhotoSelected"
                                       accept=".jpg,.jpeg,.png" style="display:none;" />
                        </div>
                    </div>

                    <!-- Секция: Основная информация -->
                    <div class="mb-4">
                        <h5 class="section-title fw-semibold border-bottom pb-2 mb-3 text-uppercase tracking-wider">
                            Основная информация
                        </h5>

                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label small fw-semibold text-muted mb-1">Фамилия</label>
                                <InputText @bind-Value="_editMember.LastName"
                                           class="form-control rounded-3" placeholder="Иванов" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-semibold text-muted mb-1">Имя</label>
                                <InputText @bind-Value="_editMember.FirstName"
                                           class="form-control rounded-3" placeholder="Иван" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-semibold text-muted mb-1">Отчество</label>
                                <InputText @bind-Value="_editMember.ParentName"
                                           class="form-control rounded-3" placeholder="Иванович" />
                            </div>
                        </div>

                        <div class="row g-3 mt-1">
                            <div class="col-md-6">
                                <label class="form-label small fw-semibold text-muted mb-1">Пол</label>
                                <InputSelect @bind-Value="_editMember.Gender"
                                             class="form-select rounded-3">
                                    <option value="@MyGender.Male">🧑 Мужчина</option>
                                    <option value="@MyGender.Female">👩 Женщина</option>
                                </InputSelect>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-semibold text-muted mb-1">Дата рождения</label>
                                <InputDate TValue="DateTime" Value="_editMember.DateOfBirth"
                                           ValueChanged="@(d => _editMember.DateOfBirth = d)"
                                           ValueExpression="@(() => _editMember.DateOfBirth)"
                                           class="form-control rounded-3" />
                            </div>
                        </div>
                    </div>

                    <!-- Секция: Семейные связи -->
                    <div class="mb-4">
                        <h5 class="section-title fw-semibold border-bottom pb-2 mb-3 text-uppercase tracking-wider">
                            Семейные связи
                        </h5>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-semibold text-muted mb-1">Отец</label>
                                <InputSelect @bind-Value="_editMember.FatherId"
                                             class="form-select rounded-3">
                                    <option value="">-- Выберите отца --</option>
                                    @if (_allMembers != null)
                                    {
                                        @foreach (var m in _allMembers.Where(x => x.Gender == MyGender.Male && x.Id != Id))
                                        {
                                            <option value="@m.Id">@m.LastName @m.FirstName</option>
                                        }
                                    }
                                </InputSelect>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label small fw-semibold text-muted mb-1">Мать</label>
                                <InputSelect @bind-Value="_editMember.MotherId"
                                             class="form-select rounded-3">
                                    <option value="">-- Выберите мать --</option>
                                    @if (_allMembers != null)
                                    {
                                        @foreach (var m in _allMembers.Where(x => x.Gender == MyGender.Female && x.Id != Id))
                                        {
                                            <option value="@m.Id">@m.LastName @m.FirstName</option>
                                        }
                                    }
                                </InputSelect>
                            </div>
                        </div>
                    </div>

                    <!-- Поле Супруг / Супруга -->
                    <div class="col-md-12 mt-3">
                        <label class="form-label small fw-semibold text-muted mb-1">
                            @(_editMember.Gender == MyGender.Male ? "Жена / Супруга" : "Муж / Супруг")
                            <!-- Для страницы EditMember замените _newMember на _editMember -->
                        </label>
                        <InputSelect @bind-Value="SelectedSpouseId" class="form-select rounded-3">
                            <option value="">-- Нет супруга (холост / незамужем) --</option>
                            @if (_editMember.Gender == MyGender.Male)
                            {
                                <!-- Если текущий член — мужчина, выбираем жену из женщин -->
                                @foreach (var m in _allMembers.Where(x => x.Gender == MyGender.Female))
                                {
                                    <option value="@m.Id">@m.LastName @m.FirstName @m.ParentName</option>
                                }
                            }
                            else
                            {
                                <!-- Если текущий член — женщина, выбираем мужа из мужчин -->
                                @foreach (var m in _allMembers.Where(x => x.Gender == MyGender.Male))
                                {
                                    <option value="@m.Id">@m.LastName @m.FirstName @m.ParentName</option>
                                }
                            }
                        </InputSelect>
                    </div>


                    <!-- Секция: Биография -->
                    <div class="mb-4 mt-4">
                        <h5 class="section-title fw-semibold border-bottom pb-2 mb-3 text-uppercase tracking-wider">
                            Биография и примечания
                        </h5>

                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label small fw-semibold text-muted mb-1">История жизни, воспоминания или заметки</label>
                                <InputTextArea @bind-Value="_editMember.Biography"
                                               class="form-control rounded-3"
                                               rows="5"
                                               placeholder="Расскажите об основных событиях в жизни человека, его профессии, увлечениях или важных семейных воспоминаниях..." />
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between gap-2 pt-3 border-top">
                        <button type="button" class="btn btn-light rounded-3 px-4" @onclick='(() => Nav.NavigateTo("ftree"))'>
                            Отмена
                        </button>
                        <button type="submit" class="btn btn-primary rounded-3 px-4 fw-medium shadow-sm">
                            Сохранить изменения
                        </button>
                    </div>
                    </EditForm>
                }
            </div>
        </div>
    </div>

@code {
    [Parameter] public int Id { get; set; }

    private FamilyMemberDto? _editMember;
    private List<FamilyMemberDto>? _allMembers;
    private int? SelectedSpouseId
    {
        get => _editMember.SpouseIds != null && _editMember.SpouseIds.Any()
               ? _editMember.SpouseIds.First()
               : null;
        set
        {
            _editMember.SpouseIds ??= new List<int>();
            _editMember.SpouseIds.Clear(); // Очищаем старые связи

            if (value.HasValue && value.Value != 0)
            {
                _editMember.SpouseIds.Add(value.Value); // Добавляем ID нового супруга
            }
        }
    }
    private bool _isLoading = true;

    private InputFile? _fileInput;
    private IBrowserFile? _selectedFile;
    private string? _previewPhotoUrl;
    private bool _photoDeleted = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _isLoading = true;
            _allMembers = await FamilyService.GetAllMembersAsync() ?? new List<FamilyMemberDto>();

            // Находим редактируемого родственника из общего списка
            var current = _allMembers.FirstOrDefault(x => x.Id == Id);
            if (current != null)
            {
                // Клонируем объект, чтобы изменения не применялись к дереву до сохранения
                _editMember = new FamilyMemberDto
                {
                    Id = current.Id,
                    FirstName = current.FirstName,
                    LastName = current.LastName,
                    ParentName = current.ParentName,
                    Gender = current.Gender,
                    DateOfBirth = current.DateOfBirth,
                    Biography = current.Biography,
                    PhotoUrl = current.PhotoUrl,
                    FatherId = current.FatherId,
                    MotherId = current.MotherId,
                    SpouseIds = current.SpouseIds != null ? new List<int>(current.SpouseIds) : null
                };

                _previewPhotoUrl = _editMember.PhotoUrl;
                SelectedSpouseId = _editMember.SpouseIds?.FirstOrDefault();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка инициализации формы редактирования: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task TriggerFileInput()
    {
        if (_fileInput?.Element != null)
        {
            await JS.InvokeVoidAsync("HTMLElement.prototype.click.call", _fileInput.Element);
        }
    }

    private async Task OnPhotoSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        var allowedExtensions = new[] { ".jpg", ".jpeg", ".png" };
        var extension = Path.GetExtension(file.Name).ToLower();

        if (!allowedExtensions.Contains(extension) || file.Size > 1024 * 1024 * 2)
        {
            Console.WriteLine("Ошибка: неверный формат или размер файла > 2МБ");
            return;
        }

        _selectedFile = file;
        _photoDeleted = false;

        using var stream = _selectedFile.OpenReadStream(2 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        _previewPhotoUrl = $"data:{_selectedFile.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
    }

    private void ClearSelectedPhoto()
    {
        _selectedFile = null;
        _previewPhotoUrl = null;
        if (_editMember != null)
        {
            _editMember.PhotoUrl = string.Empty;
        }
        _photoDeleted = true; // Сигнал для бэкенда удалить картинку
    }


    private async Task HandleFormSubmit()
    {        
        if (_editMember == null) return;

        // Если пользователь нажал "Удалить фото", очищаем поле перед отправкой DTO
        if (_photoDeleted)
        {
            _editMember.PhotoUrl = string.Empty;
        }

        var success = await FamilyService.UpdateMemberAsync(Id, _editMember);

        if (success)
        {
            // Если выбран новый файл фотографии — отправляем его вторичным запросом
            if (_selectedFile != null)
            {
                await FamilyService.UploadPhotoAsync(Id.ToString(), _selectedFile);
            }

            Nav.NavigateTo("ftree");
        }
    }

    private void GoBack()
    {
        Nav.NavigateTo("ftree");
    }

}
