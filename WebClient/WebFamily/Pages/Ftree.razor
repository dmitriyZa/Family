@page "/ftree"
@using WebFamily.Services
@using Family.Shared
@using WebFamily.Models
@using WebFamily.Pages.Components
@inject HttpClient Http
@inject FamilyNodeFactory NodeFactory
@inject NavigationManager Nav
@inject IFamilyClientService FamilyService
@inject IJSRuntime JS



<PageTitle>Семейное дерево</PageTitle>

<!-- Красивая верхняя панель страницы -->
<div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-4">
    <div>
        <h1 class="h2 fw-bold text-gradient mb-1">Мое семейное дерево</h1>
        <p class="text-muted small mb-0">Управление связями и просмотр карточек родственников</p>
    </div>
    <Button Color="ButtonColor.Primary" Class="px-4 py-2 shadow-sm rounded-3 fw-medium"
            @onclick='(() => Nav.NavigateTo("add-member"))'>
        <i class="bi bi-person-plus-fill me-2"></i> Добавить родственника
    </Button>
</div>

<!-- Контейнер для дерева с мягкими тенями -->
<div class="tree-container position-relative rounded-4 shadow-sm overflow-hidden border">

    <!-- Индикатор загрузки, поддерживающий темную тему -->
    @if (_isLoading)
    {
        <div
            class="loader-overlay position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center">
            <div class="text-center p-4 rounded-3 shadow-sm bg-body border">
                <div class="spinner-border text-primary mb-3" style="width: 2.5rem; height: 2.5rem;" role="status"></div>
                <p class="mb-0 fw-medium">Загрузка данных...</p>
                <p class="text-muted small mb-0">Пожалуйста, подождите</p>
            </div>
        </div>
    }

    <!-- Область отрисовки дерева -->
    <div class="tree-viewport">
        @if (_options != null)
        {
            <FamilyTree @ref=@_familyTree TNode="CustomNode" TreeId="family-tree-main" Options=@_options />
        }
    </div>
    <!-- Вызов твоего нового изолированного компонента -->
    <MemberDetailsModal Member="_selectedMember" OnClose="CloseDetails" />
</div>

@code {
    private RootOptions<CustomNode> _options = null!;
    private FamilyTree<CustomNode> _familyTree = null!;
    private bool _isLoading = true;
    private CustomNode? _selectedMember;

    private void OpenBlazorDetails(string nodeId)
    {
        // Ищем узел в уже загруженном списке дерева по его Id
        if (_options?.FamilyTreeOptions?.Nodes != null)
        {
            _selectedMember = _options.FamilyTreeOptions.Nodes.FirstOrDefault(n => n.Id == nodeId);
            StateHasChanged(); // Принудительно обновляем интерфейс Blazor
        }
    }

    private void CloseDetails()
    {
        _selectedMember = null;
        StateHasChanged();
    }

    

    protected override async Task OnInitializedAsync()
    {
        await ReloadTree();
    }

    private void InitializeOptions(List<CustomNode> nodes)
    {
        _options = new(
            FamilyTreeOptions: new(
                MiniMap: false,
                Mode: "light",
                Template: Template.Tommy,
                NodeBinding: new Dictionary<string, string>()
                {
                    { NodeBinding.Field0, "name" },
                    { NodeBinding.Field1, "birthDate" },
                    { NodeBinding.Field2, "occupation" },
                    { "field_3", "biography" },
                    { NodeBinding.Img0, "photo" }
                },
                Nodes: nodes,
                NodeMenu: new()
                {
                    // Заменяем встроенное окно "Details" на кастомный клик C#
                    Details = new(Text: "Открыть анкету",
                    OnClick: (Action<string, object?>)((nodeId, _) => OpenBlazorDetails(nodeId))),

                    Edit = new(Text: "Редактировать",
                        OnClick: (Action<string, object?>)((nodeId, _) => Nav.NavigateTo($"/Family/edit-member/{nodeId}"))),
                    Remove = new(Text: "Удалить",
                        OnClick: (Action<string, object?>)((nodeId, _) => OnManualDelete(nodeId)))
                },
                EditForm: new(
                PhotoBinding: "photo", // Передаем имя свойства с маленькой буквы
                Elements: new List<EditFormElement>()
            )
            )
        );
    }

    

    private async void OnManualDelete(string nodeId)
    {
        if (string.IsNullOrEmpty(nodeId)) return;

        if (int.TryParse(nodeId, out int idToDelete))
        {
            try
            {
                _isLoading = true;
                StateHasChanged();

                var success = await FamilyService.DeleteMemberAsync(idToDelete);
                if (success)
                {
                    await _familyTree.RemoveNodeAsync(nodeId);
                    await ReloadTree();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Ошибка при удалении: {ex.Message}");
            }
            finally
            {
                _isLoading = false;
                StateHasChanged();
            }
        }
        else
        {
            await _familyTree.RemoveNodeAsync(nodeId);
        }
    }

    private async Task ReloadTree()
    {
        try
        {
            _isLoading = true;
            _options = null!; // Сбрасываем старое дерево для чистого рендеринга
            StateHasChanged();

            var members = await FamilyService.GetAllMembersAsync();

            if (members != null)
            {
                var nodes = NodeFactory.CreateTree(members);
                InitializeOptions(nodes);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки дерева: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }
}



