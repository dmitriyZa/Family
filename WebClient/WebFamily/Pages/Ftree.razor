@page "/ftree"
@using WebFamily.Services
@using Family.Shared
@using WebFamily.Models
@inject HttpClient Http
@inject FamilyNodeFactory NodeFactory
@inject NavigationManager Nav
@inject FamilyMappingService MappingService
@inject IFamilyClientService FamilyService
@inject IJSRuntime JS

<PageTitle>Семейное дерево</PageTitle>

<h1>Мое семейное дерево</h1>

<div class="mb-2 text-end">
    <Button Color="ButtonColor.Primary" @onclick='(() => Nav.NavigateTo("add-member"))'> Добавить родственника </Button>
</div>

<div class="position-relative" style="height: 700px; border: 1px solid #ccc;">

    <!-- Индикатор загрузки накладывается поверх, не ломая разметку дерева -->
    @if (_isLoading)
    {
        <div class="position-absolute top-0 start-0 w-100 h-100 bg-white bg-opacity-75 d-flex align-items-center justify-content-center" style="z-index: 10;">
            <div class="text-center">
                <div class="spinner-border text-primary mb-2" role="status"></div>
                <p class="mb-0 text-muted fw-medium">Загрузка данных...</p>
            </div>
        </div>
    }

    <!-- Дерево рендерится всегда, когда готовы опции -->
    @if (_options != null)
    {
        <FamilyTree @ref=@_familyTree
                    TNode="CustomNode"
                    TreeId="family-tree-main"
                    Options=@_options />
    }
</div>

@code {
    private RootOptions<CustomNode> _options = null!;
    private FamilyTree<CustomNode> _familyTree = null!;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await ReloadTree();
    }

    private void InitializeOptions(List<CustomNode> nodes)
    {
        _options = new(
            FamilyTreeOptions: new(
                MiniMap: false,
                Mode: "light",
                Template: Template.Tommy,
                NodeBinding: new Dictionary<string, string>()
                {
                    { NodeBinding.Field0, "name" },
                    { NodeBinding.Field1, "birthDate" },
                    { NodeBinding.Img0, "photo" }
                },
                Nodes: nodes,
                NodeMenu: new()
                {
                    Details = new(Text: "Открыть анкету"),
                    // Перенаправляем на нашу кастомную страницу по ID
                    Edit = new(Text: "Редактировать",
                        OnClick: (Action<string, object?>)((nodeId, _) => Nav.NavigateTo($"/family/edit-member/{nodeId}"))),
                    Remove = new(Text: "Удалить",
                        OnClick: (Action<string, object?>)((nodeId, _) => OnManualDelete(nodeId)))
                },
                EditForm: null 
            )
        );
    }

    private async void OnManualDelete(string nodeId)
    {
        if (string.IsNullOrEmpty(nodeId)) return;

        if (int.TryParse(nodeId, out int idToDelete))
        {
            try
            {
                _isLoading = true;
                StateHasChanged();

                var success = await FamilyService.DeleteMemberAsync(idToDelete);
                if (success)
                {
                    await _familyTree.RemoveNodeAsync(nodeId);
                    await ReloadTree();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Ошибка при удалении: {ex.Message}");
            }
            finally
            {
                _isLoading = false;
                StateHasChanged();
            }
        }
        else
        {
            await _familyTree.RemoveNodeAsync(nodeId);
        }
    }

    private async Task ReloadTree()
    {
        try
        {
            _isLoading = true;
            _options = null!; // Сбрасываем старое дерево для чистого рендеринга
            StateHasChanged();

            var members = await FamilyService.GetAllMembersAsync();

            if (members != null)
            {
                var nodes = NodeFactory.CreateTree(members);
                InitializeOptions(nodes);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки дерева: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }


}
