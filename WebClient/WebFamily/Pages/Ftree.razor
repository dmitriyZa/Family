@page "/ftree"
@using WebFamily.Services
@using Family.Shared
@using WebFamily.Models
@inject HttpClient Http
@inject FamilyNodeFactory NodeFactory
@inject NavigationManager Nav
@inject FamilyMappingService MappingService
@inject IJSRuntime JS


<PageTitle>Семейное дерево</PageTitle>

<h1>Мое семейное дерево</h1>

@if (_isLoading && _options == null)
{
    <p><em>Загрузка данных...</em></p>
}
else
{
    <div class="mb-2 text-end">
    <Button Color="ButtonColor.Primary" Class="" @onclick='(() => Nav.NavigateTo("/add-member"))'> Добавить родственника </Button>    
    </div>
    <InputFile @ref="_fileInput" 
               
               id="photoUploadInput"
               OnChange="HandleFileSelected"
               accept=".jpg,.jpeg,.png"
               style="display:none;" />

    <div style="height: 700px; border: 1px solid #ccc;">
        <FamilyTree @ref=@_familyTree
                    TNode="CustomNode"
                    OnUpdatedNode=@OnUpdateNode
                    OnTextboxButtonClicked=@OnTextboxButtonClickedAsync
                    TreeId="family-tree-main"
                    Options=@_options />
    </div>
}

@code {
    private RootOptions<CustomNode> _options = null!;
    private FamilyTree<CustomNode> _familyTree = null!;
    private bool _isLoading = true;
    private string? _currentNodeId;
    private InputFile? _fileInput;
    private TaskCompletionSource<string?>? _photoUploadTcs;

    protected override async Task OnInitializedAsync()
    {
        await ReloadTree();
    }

    private void InitializeOptions(List<CustomNode> nodes)
    {
        _options = new(
            FamilyTreeOptions: new(
                MiniMap:false,                
                Mode: "light",
                Template: Template.Tommy,                
                NodeBinding: new Dictionary<string, string>()
                            {
                    { NodeBinding.Field0, "name" },
                    { NodeBinding.Field1, "birthDate" },
                    { NodeBinding.Img0, "photo" }
                            },
                Nodes: nodes,
                NodeMenu: new()
                    {
                        Details = new(Text: "Открыть анкету"),
                        Edit = new(Text: "Редактировать"),
                        Remove = new(Text: "Удалить",
                            OnClick: (Action<string, object?>)((nodeId, _) => OnManualDelete(nodeId)))
                    },
                EditForm: new(
                    PhotoBinding: "photo",
                    CancelBtn: "Отмена",
                    SaveAndCloseBtn: "Сохранить",
                    Elements: new List<EditFormElement>()
                                {
                        new(Type: "textbox", Label: "ФИО", Binding: "name"),
                        new(Type: "textbox", Label: "Дата рождения", Binding: "birthDate"),
                        new(Type: "textbox", Label: "Photo", Binding: "photo", Btn: "Загрузить фото"),
                        new(Type: "textbox", Label: "Биография", Binding: "biography"),                        
                        new(Type: "textbox", Label: "Пол", Binding: "gender",
                        Options: new List<Dictionary<string, string>>()
              {
                new() { { "value", "male" }, { "text", "Муж" } },
                new() { { "value", "female" }, { "text", "Жен" } }
              })
              }
                )
            )
        );
    }  
    

    private async Task<string?> OnTextboxButtonClickedAsync(TextboxButtonClickedArgs args)
    {
        if (args.BindingName == "photo")
        {
            _currentNodeId = args.NodeId; // Сохраняем ID текущего родственника
            _photoUploadTcs = new TaskCompletionSource<string?>();

            if (_fileInput?.Element != null)
            {
                await JS.InvokeVoidAsync("HTMLElement.prototype.click.call", _fileInput.Element);
            }

            return await _photoUploadTcs.Task;
        }
        return string.Empty;
    }



    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null || string.IsNullOrEmpty(_currentNodeId)) return;

        try
        {
            using var content = new MultipartFormDataContent();
            var fileContent = new StreamContent(file.OpenReadStream(5 * 1024 * 1024));
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            content.Add(fileContent, "file", file.Name);

            var response = await Http.PostAsync($"api/Family/{_currentNodeId}/upload-photo", content);

            if (response.IsSuccessStatusCode)
            {
                // Читаем как JsonElement, чтобы динамически достать поле "url"
                var result = await response.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();

                if (result.TryGetProperty("url", out var urlProperty))
                {
                    var photoPath = urlProperty.GetString();

                    // Передаем путь в форму дерева.
                    // Библиотека сама подставит этот текст в TextBox.
                    _photoUploadTcs?.SetResult(photoPath);
                }
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки: {ex.Message}");
            _photoUploadTcs?.SetResult(null);
        }
    }





    private async Task OnUpdateNode(UpdateNodeArgs<CustomNode> args)
    {
        foreach (var updatedNode in args.UpdateNodesData)
        {
            var dto = MappingService.MapNodeToDto(updatedNode);

            // ВАЖНО: убедись, что в dto поле называется Photo или PhotoUrl
            // Если в MappingService ты его не заполнил, здесь будет null
            if (!string.IsNullOrEmpty(dto.PhotoUrl))
            {
                var baseUri = Http.BaseAddress?.ToString();
                if (!string.IsNullOrEmpty(baseUri) && dto.PhotoUrl.StartsWith(baseUri))
                {
                    dto.PhotoUrl = dto.PhotoUrl.Replace(baseUri, "");
                }
            }

            await Http.PutAsJsonAsync($"api/Family/{dto.Id}", dto);
        }
        await ReloadTree();
    }



    private async void OnManualDelete(string nodeId)
    {
        if (string.IsNullOrEmpty(nodeId)) return;

        // Библиотека иногда использует временные ID, их не шлем на бэк
        if (int.TryParse(nodeId, out int idToDelete))
        {
            try
            {
                var response = await Http.DeleteAsync($"api/Family/{idToDelete}");
                if (response.IsSuccessStatusCode)
                {
                    // Важно: после удаления на бэке нужно удалить узел визуально
                    await _familyTree.RemoveNodeAsync(nodeId);
                    await ReloadTree();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Ошибка при удалении: {ex.Message}");
            }
        }
        else
        {
            // Если это временная нода (не из БД), просто удаляем визуально
            await _familyTree.RemoveNodeAsync(nodeId);
        }
    }
       

    private async Task ReloadTree()
    {
        try
        {
            _isLoading = true;
            _options = null!; // Сбрасываем опции для чистого рендеринга
            StateHasChanged();

            var members = await Http.GetFromJsonAsync<List<FamilyMemberDto>>("api/Family/all");

            if (members != null)
            {
                // Добавляем базовый адрес бэкенда к путям фото
                foreach (var m in members.Where(x => !string.IsNullOrEmpty(x.PhotoUrl)))
                {
                    if (!m.PhotoUrl.StartsWith("http"))
                    {
                        // Http.BaseAddress обычно содержит "https://localhost:7001/"
                        m.PhotoUrl = $"{Http.BaseAddress}{m.PhotoUrl}";
                    }
                }
                var nodes = NodeFactory.CreateTree(members);
                InitializeOptions(nodes);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }
}
