@page "/ftree"
@using WebFamily.Services
@using Family.Shared
@using WebFamily.Models
@inject HttpClient Http
@inject FamilyNodeFactory NodeFactory
@inject NavigationManager Nav
@inject FamilyMappingService MappingService

<PageTitle>Семейное дерево</PageTitle>

<h1>Мое семейное дерево</h1>

@if (_isLoading && _options == null)
{
    <p><em>Загрузка данных...</em></p>
}
else
{
    <div class="mb-2 text-end">
    <Button Color="ButtonColor.Primary" Class="" @onclick='(() => Nav.NavigateTo("/add-member"))'> Добавить родственника </Button>    
    </div>
    <div style="height: 700px; border: 1px solid #ccc;">
        <FamilyTree @ref=@_familyTree
                    TNode="CustomNode"
                    OnUpdatedNode=@OnUpdateNode                    
                    TreeId="family-tree-main"
                    Options=@_options />
    </div>
}

@code {
    private RootOptions<CustomNode> _options = null!;
    private FamilyTree<CustomNode> _familyTree = null!;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await ReloadTree();
    }

    private void InitializeOptions(List<CustomNode> nodes)
    {
        _options = new(
            FamilyTreeOptions: new(
                MiniMap:false,                
                Mode: "light",
                Template: Template.Tommy,
                NodeBinding: new Dictionary<string, string>()
                            {
                    { NodeBinding.Field0, "name" },
                    { NodeBinding.Field1, "birthDate" },
                    { NodeBinding.Img0, "photo" }
                            },
                Nodes: nodes,
                NodeMenu: new()
                    {
                        Details = new(Text: "Открыть анкету"),
                        Edit = new(Text: "Редактировать"),
                        Remove = new(Text: "Удалить",
                            OnClick: (Action<string, object?>)((nodeId, _) => OnManualDelete(nodeId)))
                    },
                EditForm: new(
                    Elements: new List<EditFormElement>()
                                {
                        new(Type: "textbox", Label: "ФИО", Binding: "name"),
                        new(Type: "textbox", Label: "Дата рождения", Binding: "birthDate"),
                        new(Type: "textbox", Label: "Биография", Binding: "biography"),
                        new(Type: "textbox", Label: "Пол", Binding: "gender",
                        Options: new List<Dictionary<string, string>>()
              {
                new() { { "value", "male" }, { "text", "Муж" } },
                new() { { "value", "female" }, { "text", "Жен" } }
              })
                                }
                )
            )
        );
    }

    private async Task OnUpdateNode(UpdateNodeArgs<CustomNode> args)
    {
        // Обработка обновления
        foreach (var updatedNode in args.UpdateNodesData)
        {
            var dto = MappingService.MapNodeToDto(updatedNode);
            await Http.PutAsJsonAsync($"api/Family/{dto.Id}", dto);
        }        

        await ReloadTree();
    }

    private async void OnManualDelete(string nodeId)
    {
        if (string.IsNullOrEmpty(nodeId)) return;

        // Библиотека иногда использует временные ID, их не шлем на бэк
        if (int.TryParse(nodeId, out int idToDelete))
        {
            try
            {
                var response = await Http.DeleteAsync($"api/Family/{idToDelete}");
                if (response.IsSuccessStatusCode)
                {
                    // Важно: после удаления на бэке нужно удалить узел визуально
                    await _familyTree.RemoveNodeAsync(nodeId);
                    await ReloadTree();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Ошибка при удалении: {ex.Message}");
            }
        }
        else
        {
            // Если это временная нода (не из БД), просто удаляем визуально
            await _familyTree.RemoveNodeAsync(nodeId);
        }
    }




    private async Task ReloadTree()
    {
        try
        {
            _isLoading = true;
            _options = null!; // Сбрасываем опции для чистого рендеринга
            StateHasChanged();

            var members = await Http.GetFromJsonAsync<List<FamilyMemberDto>>("api/Family/all");

            if (members != null)
            {
                var nodes = NodeFactory.CreateTree(members);
                InitializeOptions(nodes);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }
}
