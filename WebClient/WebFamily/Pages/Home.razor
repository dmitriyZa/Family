@page "/"

<PageTitle>Семейный Архив</PageTitle>

<div class="welcome-container container-fluid py-5">
    <!-- Заголовок с акцентом на ваш фирменный фиолетовый цвет -->
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold text-dark mb-2">Добро пожаловать в Семейный Архив</h1>
        <p class="text-muted fst-italic fs-5">Храните историю и традиции вашего рода в одном месте</p>
    </div>

    <!-- Красивая интерактивная обертка для фотографии -->
    <div class="d-flex justify-content-center">
        <div class="family-image-card shadow-sm rounded-4 overflow-hidden bg-white">
            <Image Src="./sample-data/family.png"
                   Class="img-fluid d-block"
                   Alt="Семейная фотография" />
        </div>
    </div>
</div>




